from itertools import permutations

def solve_cryptarithmetic(words, result_word):
    letters = set(''.join(words) + result_word)

    # More than 10 unique letters means impossible
    if len(letters) > 10:
        return None

    letters = list(letters)

    # First letters cannot be zero
    leading = {w[0] for w in words + [result_word]}

    for perm in permutations(range(10), len(letters)):
        mapping = dict(zip(letters, perm))

        # Check leading zero condition
        if any(mapping[l] == 0 for l in leading):
            continue

        def to_num(w):
            return int(''.join(str(mapping[c]) for c in w))

        # Check if sum is correct
        if sum(to_num(w) for w in words) == to_num(result_word):
            return mapping

    return None


words = ['SEND', 'MORE']
result_word = 'MONEY'

mapping = solve_cryptarithmetic(words, result_word)

if mapping:
    print("Solution:", mapping)
    print("SEND + MORE = MONEY")

    for word in words:
        print(f"{word} = {int(''.join(str(mapping[c]) for c in word))}")

    print(f"{result_word} = {int(''.join(str(mapping[c]) for c in result_word))}")

else:
    print("No solution found.")
